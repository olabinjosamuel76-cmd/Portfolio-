<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Alex Carter | Video Editor</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins', sans-serif;
}

body{
    background:#0b0b0f;
    color:#fff;
    overflow-x:hidden;
}

/* HERO */
.hero{
    height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:flex-start;
    padding:0 10%;
    position:relative;
}

.hero h1{
    font-size:3.5rem;
    opacity:0;
    transform:translateY(30px);
    animation:fadeUp 1s ease forwards;
}

.hero p{
    margin-top:15px;
    max-width:500px;
    opacity:0;
    transform:translateY(30px);
    animation:fadeUp 1s ease forwards;
    animation-delay:0.3s;
    color:#bdbdbd;
}

.hero span{
    color:#00ffd5;
}

.btn{
    margin-top:25px;
    padding:12px 25px;
    background:#00ffd5;
    color:#000;
    border:none;
    border-radius:6px;
    cursor:pointer;
    text-decoration:none;
    display:inline-block;
    transition:0.3s;
    opacity:0;
    animation:fadeUp 1s ease forwards;
    animation-delay:0.6s;
}

.btn:hover{
    transform:scale(1.05);
}

/* SECTIONS */
section{
    padding:100px 10%;
}

h2{
    font-size:2rem;
    margin-bottom:40px;
    position:relative;
}

/* underline animation */
h2::after{
    content:'';
    width:60px;
    height:3px;
    background:#00ffd5;
    position:absolute;
    left:0;
    bottom:-10px;
}

/* CARDS */
.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.card{
    background:#15151d;
    padding:25px;
    border-radius:12px;
    transition:0.4s ease;
    opacity:0;
    transform:translateY(40px);
}

.card:hover{
    transform:translateY(-10px);
    box-shadow:0 10px 30px rgba(0,255,213,0.1);
}

/* floating glow background */
.glow{
    position:absolute;
    width:400px;
    height:400px;
    background:#00ffd5;
    filter:blur(150px);
    opacity:0.08;
    top:20%;
    right:10%;
    border-radius:50%;
    animation:float 6s ease-in-out infinite;
}

/* FOOTER */
footer{
    text-align:center;
    padding:40px;
    background:#111;
    color:#888;
}

/* ANIMATIONS */
@keyframes fadeUp{
    to{
        opacity:1;
        transform:translateY(0);
    }
}

@keyframes float{
    0%,100%{ transform:translateY(0px); }
    50%{ transform:translateY(-30px); }
}

/* SCROLL REVEAL */
.show{
    opacity:1 !important;
    transform:translateY(0) !important;
}
</style>
</head>

<body>

<div class="hero">
    <div class="glow"></div>

    <h1>I Help YouTubers <span>Go Viral</span></h1>
    <p>High-retention video editing designed to increase watch time, engagement, and subscriber growth.</p>
    <a href="#contact" class="btn">Work With Me</a>
</div>

<section>
    <h2>About Me</h2>
    <div class="card reveal">
        I’m Alex Carter, a professional video editor with 3+ years of experience helping creators grow through cinematic storytelling, pacing, and retention-focused editing.
    </div>
</section>

<section>
    <h2>Services</h2>
    <div class="grid">
        <div class="card reveal">YouTube Long-form Editing</div>
        <div class="card reveal">Short-form Viral Clips</div>
        <div class="card reveal">Color Grading & Sound Design</div>
    </div>
</section>

<section>
    <h2>Portfolio</h2>
    <div class="grid">
        <div class="card reveal">100K+ Views Documentary Edit</div>
        <div class="card reveal">High-retention YouTube Video</div>
        <div class="card reveal">Viral TikTok Compilation</div>
    </div>
</section>

<section>
    <h2>Testimonials</h2>
    <div class="grid">
        <div class="card reveal">“My engagement doubled in 2 weeks.”</div>
        <div class="card reveal">“Best editor I’ve worked with.”</div>
        <div class="card reveal">“Helped me go viral instantly.”</div>
    </div>
</section>

<section id="contact">
    <h2>Let’s Work Together</h2>
    <div class="card reveal">
        Email: alexeditor@email.com<br><br>
        <a class="btn">Get Started</a>
    </div>
</section>

<footer>
    © 2026 Alex Carter — Premium Video Editing
</footer>

<script>
// scroll animation system
const elements = document.querySelectorAll('.reveal');

const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
        if(entry.isIntersecting){
            entry.target.classList.add('show');
        }
    });
}, { threshold: 0.1 });

elements.forEach(el => observer.observe(el));
</script>

</body>
</html>
